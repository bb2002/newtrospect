{
  "name": "@newtrospect/worker",
  "version": "0.0.0",
  "private": true,
  "description": "Cloudflare Workers + Workers AI + D1 백엔드",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit && tsc --noEmit -p scripts/tsconfig.json",
    "db:migrate:local": "wrangler d1 migrations apply newtrospect --local",
    "db:migrate:remote": "wrangler d1 migrations apply newtrospect --remote",
    "spike:s2": "tsx scripts/spike-s2.ts"
  },
  "dependencies": {
    "@newtrospect/core": "workspace:*",
    "hono": "^4.6.11"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "wrangler": "^3.91.0"
  }
}
